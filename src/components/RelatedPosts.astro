---
import type { CollectionEntry } from "astro:content";
import { getRelatedPosts } from "@/utils/getRelatedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";
import { useTranslations } from "@/i18n";
import Datetime from "./Datetime.astro";
import config from "@/config";

type Props = {
  post: CollectionEntry<"posts">;
  allPosts: CollectionEntry<"posts">[];
  limit?: number;
};

const { post, allPosts, limit = 3 } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const related = getRelatedPosts(post, allPosts, limit);

const rssHref = `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`;

const LANG_BADGE: Record<string, { flag: string; label: string }> = {
  vi: { flag: "🇻🇳", label: "VI" },
  en: { flag: "🇺🇸", label: "EN" },
};
---

{
  related.length > 0 && (
    <section
      aria-labelledby="keep-reading-heading"
      class="bg-surface border-border mt-12 rounded-lg border p-5 sm:p-6"
    >
      <h2 id="keep-reading-heading" class="text-xl font-semibold">
        {t.post.keepReading}
      </h2>
      <p class="text-muted-foreground mt-1 text-sm">{t.post.keepReadingDesc}</p>

      <ul class="mt-5 grid gap-x-6 gap-y-5 sm:grid-cols-2">
        {related.map(rp => {
          const badge = LANG_BADGE[rp.data.lang ?? "vi"] ?? LANG_BADGE.vi;
          return (
            <li class="related-item">
              <a
                href={getPostUrl(rp.id, rp.filePath, Astro.currentLocale)}
                class="text-accent text-base font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
              >
                <span transition:name={toTransitionName(rp.data.title)}>
                  {rp.data.title}
                </span>
              </a>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                <Datetime
                  pubDatetime={rp.data.pubDatetime}
                  modDatetime={rp.data.modDatetime}
                  timezone={rp.data.timezone}
                />
                <span class="text-muted-foreground border-border rounded border px-1 py-0.5 text-xs leading-none font-medium">
                  {badge.flag} {badge.label}
                </span>
              </div>
            </li>
          );
        })}
      </ul>

      <p class="border-border text-muted-foreground mt-6 border-t pt-4 text-sm">
        {t.post.subscribePrompt}{" "}
        <a
          href={rssHref}
          class="text-accent decoration-dashed underline-offset-4 hover:underline"
        >
          {t.post.subscribeCta}
        </a>
      </p>
    </section>
  )
}

<style>
  /* Quiet, unhurried: a gentle lift on hover, never on a hidden default. */
  .related-item {
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .related-item:hover {
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .related-item {
      transition: none;
    }
    .related-item:hover {
      transform: none;
    }
  }
</style>
